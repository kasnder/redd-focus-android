<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.GreaseMilkyway" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/background_main</item>
        <item name="colorSecondary">@color/primary_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:textColorPrimary">@color/text_dark</item>
        <item name="android:textColorSecondary">@color/text_light</item>
        <!-- Red status bar to match toolbar -->
        <item name="android:statusBarColor">@color/header_bg</item>
        <!-- White status bar icons for contrast on red -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.GreaseMilkyway" parent="Base.Theme.GreaseMilkyway" />

    <style name="Theme.GreaseMilkyway.NoActionBar" parent="Base.Theme.GreaseMilkyway">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- White title text for red toolbar -->
    <style name="ToolbarTitleText" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- White icon tint for gear icon and back arrow on red toolbar -->
    <style name="ToolbarTheme" parent="">
        <item name="colorControlNormal">@color/white</item>
    </style>
</resources>
